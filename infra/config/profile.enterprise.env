# SecureAgnt deployment profile: enterprise
#
# Usage:
#   set -a
#   source infra/config/profile.enterprise.env
#   set +a
#   make stack-up-build
#
# This profile enables hardened defaults and assumes trusted gateway + compliance posture.
# Replace placeholder values before production use.

LLM_MODE=local_first
LLM_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
LLM_LOCAL_MODEL=qwen2.5:7b-instruct
LLM_LOCAL_API_KEY_REF=
LLM_REMOTE_BASE_URL=https://api.openai.com/v1
LLM_REMOTE_MODEL=gpt-4o-mini
LLM_REMOTE_API_KEY_REF=
LLM_REMOTE_EGRESS_ENABLED=1
LLM_REMOTE_EGRESS_CLASS=redacted_only
LLM_REMOTE_HOST_ALLOWLIST=api.openai.com
LLM_REMOTE_TOKEN_BUDGET_WINDOW_SECS=86400
LLM_REMOTE_TOKEN_BUDGET_PER_RUN=24000
LLM_REMOTE_TOKEN_BUDGET_PER_TENANT=2500000
LLM_REMOTE_TOKEN_BUDGET_PER_AGENT=500000
LLM_REMOTE_TOKEN_BUDGET_PER_MODEL=2500000
LLM_REMOTE_TOKEN_BUDGET_SOFT_ALERT_THRESHOLD_PCT=80
LLM_REMOTE_COST_PER_1K_TOKENS_USD=0.0

API_TRUSTED_PROXY_AUTH_ENABLED=1
API_TRUSTED_PROXY_SHARED_SECRET_REF=
WORKER_COMPLIANCE_SIEM_DELIVERY_ENABLED=1
WORKER_COMPLIANCE_SIEM_HTTP_ENABLED=1
WORKER_COMPLIANCE_SIEM_HTTP_AUTH_TOKEN_REF=
PAYMENT_NWC_ENABLED=1
PAYMENT_NWC_URI_REF=
PAYMENT_APPROVAL_THRESHOLD_MSAT=100000
WORKER_LOCAL_EXEC_ENABLED=0
