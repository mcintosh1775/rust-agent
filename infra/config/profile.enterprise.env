# SecureAgnt deployment profile: enterprise
#
# Usage:
#   set -a
#   source infra/config/profile.enterprise.env
#   set +a
#   make stack-up-build
#
# This profile enables hardened defaults and assumes trusted gateway + compliance posture.
# Replace placeholder values before production use.

LLM_MODE=local_first
LLM_MAX_INPUT_BYTES=262144
LLM_MAX_PROMPT_BYTES=32000
LLM_MAX_OUTPUT_BYTES=64000
LLM_LARGE_INPUT_THRESHOLD_BYTES=12000
LLM_LARGE_INPUT_POLICY=chunk_and_retrieve
LLM_LARGE_INPUT_SUMMARY_TARGET_BYTES=8000
LLM_CONTEXT_RETRIEVAL_TOP_K=6
LLM_CONTEXT_RETRIEVAL_MAX_BYTES=32000
LLM_CONTEXT_RETRIEVAL_CHUNK_BYTES=2048
LLM_ADMISSION_ENABLED=1
LLM_ADMISSION_INTERACTIVE_MAX_INFLIGHT=16
LLM_ADMISSION_BATCH_MAX_INFLIGHT=4
LLM_CACHE_ENABLED=1
LLM_CACHE_TTL_SECS=300
LLM_CACHE_MAX_ENTRIES=4096
LLM_DISTRIBUTED_ENABLED=1
LLM_DISTRIBUTED_FAIL_OPEN=1
LLM_DISTRIBUTED_OWNER=
LLM_DISTRIBUTED_ADMISSION_ENABLED=1
LLM_DISTRIBUTED_ADMISSION_LEASE_MS=30000
LLM_DISTRIBUTED_CACHE_ENABLED=1
LLM_DISTRIBUTED_CACHE_NAMESPACE_MAX_ENTRIES=8192
LLM_VERIFIER_ENABLED=1
LLM_VERIFIER_MODE=deterministic
LLM_VERIFIER_MIN_SCORE_PCT=70
LLM_VERIFIER_ESCALATE_REMOTE=1
LLM_VERIFIER_MIN_RESPONSE_CHARS=64
LLM_VERIFIER_JUDGE_BASE_URL=
LLM_VERIFIER_JUDGE_MODEL=
LLM_VERIFIER_JUDGE_API_KEY=
LLM_VERIFIER_JUDGE_API_KEY_REF=
LLM_VERIFIER_JUDGE_TIMEOUT_MS=4000
LLM_VERIFIER_JUDGE_FAIL_OPEN=1
LLM_SLO_INTERACTIVE_MAX_LATENCY_MS=6000
LLM_SLO_BATCH_MAX_LATENCY_MS=30000
LLM_SLO_ALERT_THRESHOLD_PCT=80
LLM_SLO_BREACH_ESCALATE_REMOTE=0
LLM_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
LLM_LOCAL_MODEL=qwen2.5:7b-instruct
LLM_LOCAL_API_KEY=
LLM_LOCAL_API_KEY_REF=
LLM_LOCAL_SMALL_BASE_URL=
LLM_LOCAL_SMALL_MODEL=
LLM_LOCAL_SMALL_API_KEY=
LLM_LOCAL_SMALL_API_KEY_REF=
LLM_LOCAL_INTERACTIVE_TIER=workhorse
LLM_LOCAL_BATCH_TIER=workhorse
LLM_CHANNEL_DEFAULTS_JSON=
LLM_REMOTE_BASE_URL=https://api.openai.com/v1
LLM_REMOTE_MODEL=gpt-4o-mini
LLM_REMOTE_API_KEY=
LLM_REMOTE_API_KEY_REF=
LLM_REMOTE_EGRESS_ENABLED=1
LLM_REMOTE_EGRESS_CLASS=redacted_only
LLM_REMOTE_HOST_ALLOWLIST=api.openai.com
LLM_REMOTE_TOKEN_BUDGET_WINDOW_SECS=86400
LLM_REMOTE_TOKEN_BUDGET_PER_RUN=24000
LLM_REMOTE_TOKEN_BUDGET_PER_TENANT=2500000
LLM_REMOTE_TOKEN_BUDGET_PER_AGENT=500000
LLM_REMOTE_TOKEN_BUDGET_PER_MODEL=2500000
LLM_REMOTE_TOKEN_BUDGET_SOFT_ALERT_THRESHOLD_PCT=80
LLM_REMOTE_COST_PER_1K_TOKENS_USD=0.0

SECUREAGNT_CARGO_BUILD_JOBS=2
API_TRUSTED_PROXY_AUTH_ENABLED=1
API_TRUSTED_PROXY_SHARED_SECRET=
API_TRUSTED_PROXY_SHARED_SECRET_REF=
API_AGENT_BOOTSTRAP_ENABLED=0
WORKER_COMPLIANCE_SIEM_DELIVERY_ENABLED=1
WORKER_COMPLIANCE_SIEM_HTTP_ENABLED=1
WORKER_COMPLIANCE_SIEM_HTTP_AUTH_TOKEN=
WORKER_COMPLIANCE_SIEM_HTTP_AUTH_TOKEN_REF=
PAYMENT_NWC_ENABLED=1
PAYMENT_NWC_URI=
PAYMENT_NWC_URI_REF=
PAYMENT_APPROVAL_THRESHOLD_MSAT=100000
PAYMENT_CASHU_ENABLED=0
NOSTR_SIGNER_MODE=local_key
NOSTR_SECRET_KEY=
NOSTR_SECRET_KEY_FILE=
NOSTR_NIP46_BUNKER_URI=
NOSTR_NIP46_PUBLIC_KEY=
NOSTR_NIP46_CLIENT_SECRET_KEY=
NOSTR_RELAYS=
NOSTR_PUBLISH_TIMEOUT_MS=4000
WORKER_AGENT_CONTEXT_ENABLED=0
WORKER_AGENT_CONTEXT_REQUIRED=0
WORKER_AGENT_CONTEXT_ROOT=/var/lib/secureagnt/agent-context
WORKER_AGENT_CONTEXT_REQUIRED_FILES=
WORKER_AGENT_CONTEXT_MAX_FILE_BYTES=65536
WORKER_AGENT_CONTEXT_MAX_TOTAL_BYTES=262144
WORKER_AGENT_CONTEXT_MAX_DYNAMIC_FILES_PER_DIR=8
WORKER_LOCAL_EXEC_ENABLED=0
WORKER_APPROVAL_REQUIRED_ACTION_TYPES=payment.send,message.send
# Fail closed until destinations are explicitly allowlisted per environment.
WORKER_MESSAGE_WHITENOISE_DEST_ALLOWLIST=__set_operator_npub__
WORKER_MESSAGE_SLACK_DEST_ALLOWLIST=__set_slack_channel_id__
