# SecureAgnt deployment profile: solo-lite (SQLite, single-user)
#
# Usage:
#   set -a
#   source infra/config/profile.solo-lite.env
#   set +a
#   make solo-lite-init
#   make solo-lite-smoke
#
# Note:
# - This profile is for M15-complete solo-lite runtime posture.
# - API currently exposes a scoped SQLite profile for runs, triggers, memory,
#   payments/usage reporting, core ops endpoints (summary, latency, action-latency, llm-gateway),
#   and compliance policy/purge + SIEM delivery surfaces.
# - Worker supports SQLite core run-loop mode including scheduler/memory-compaction/
#   compliance-outbox flows (these remain disabled by default in this profile for conservative local posture).

SOLO_LITE_DATABASE_URL=sqlite://./var/solo-lite/secureagnt.sqlite3
SOLO_LITE_DB_PATH=var/solo-lite/secureagnt.sqlite3
SOLO_LITE_SQLITE_JOURNAL_MODE=WAL
SOLO_LITE_SQLITE_SYNCHRONOUS=NORMAL
SOLO_LITE_SQLITE_BUSY_TIMEOUT_MS=5000

# Solo-lite favors explicit single-user posture.
LLM_MODE=local_first
# Optional local-only routing defaults.
LLM_CHANNEL_DEFAULTS_JSON=
LLM_LOCAL_BASE_URL=
LLM_LOCAL_MODELS=
LLM_LOCAL_MODEL=qwen2.5:7b-instruct
LLM_LOCAL_API_KEY=
LLM_LOCAL_API_KEY_REF=
LLM_LOCAL_SMALL_BASE_URL=
LLM_LOCAL_SMALL_MODELS=
LLM_LOCAL_SMALL_MODEL=
LLM_LOCAL_SMALL_API_KEY=
LLM_LOCAL_SMALL_API_KEY_REF=
LLM_LOCAL_INTERACTIVE_TIER=workhorse
LLM_LOCAL_BATCH_TIER=workhorse
# Optional remote fallback (disabled by default).
LLM_REMOTE_BASE_URL=
LLM_REMOTE_MODELS=
LLM_REMOTE_MODEL=
LLM_REMOTE_API_KEY=
LLM_REMOTE_API_KEY_REF=
LLM_REMOTE_EGRESS_ENABLED=0
LLM_REMOTE_EGRESS_CLASS=cloud_allowed
LLM_REMOTE_HOST_ALLOWLIST=
WORKER_TRIGGER_SCHEDULER_ENABLED=0
WORKER_MEMORY_COMPACTION_ENABLED=0
WORKER_COMPLIANCE_SIEM_DELIVERY_ENABLED=0
WORKER_COMPLIANCE_SIEM_HTTP_ENABLED=0
PAYMENT_NWC_ENABLED=0
PAYMENT_CASHU_ENABLED=0
WORKER_LOCAL_EXEC_ENABLED=0
WORKER_AGENT_CONTEXT_ENABLED=0
API_TRUSTED_PROXY_AUTH_ENABLED=0
API_AGENT_BOOTSTRAP_ENABLED=1

# White Noise signer defaults (solo-lite local signer baseline)
NOSTR_SIGNER_MODE=local_key
NOSTR_SECRET_KEY=
NOSTR_SECRET_KEY_FILE=
NOSTR_NIP46_BUNKER_URI=
NOSTR_NIP46_PUBLIC_KEY=
NOSTR_NIP46_CLIENT_SECRET_KEY=
NOSTR_RELAYS=
NOSTR_PUBLISH_TIMEOUT_MS=4000
