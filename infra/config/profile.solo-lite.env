# SecureAgnt deployment profile: solo-lite (SQLite, single-user)
#
# Usage:
#   set -a
#   source infra/config/profile.solo-lite.env
#   set +a
#   make solo-lite-init
#   make solo-lite-smoke
#
# Note:
# - This profile is for M15 solo-lite scaffolding while full runtime query parity is in progress.
# - API currently exposes a scoped SQLite profile for runs, triggers, memory,
#   payments/usage reporting, and ops summary.
# - Worker supports SQLite core run-loop mode when scheduler/memory-compaction/
#   compliance-outbox toggles stay disabled.

SOLO_LITE_DATABASE_URL=sqlite://./var/solo-lite/secureagnt.sqlite3
SOLO_LITE_DB_PATH=var/solo-lite/secureagnt.sqlite3
SOLO_LITE_SQLITE_JOURNAL_MODE=WAL
SOLO_LITE_SQLITE_SYNCHRONOUS=NORMAL
SOLO_LITE_SQLITE_BUSY_TIMEOUT_MS=5000

# Solo-lite favors explicit single-user posture.
WORKER_TRIGGER_SCHEDULER_ENABLED=0
WORKER_MEMORY_COMPACTION_ENABLED=0
WORKER_COMPLIANCE_SIEM_DELIVERY_ENABLED=0
WORKER_COMPLIANCE_SIEM_HTTP_ENABLED=0
PAYMENT_NWC_ENABLED=0
PAYMENT_CASHU_ENABLED=0
WORKER_LOCAL_EXEC_ENABLED=0
WORKER_AGENT_CONTEXT_ENABLED=0
API_TRUSTED_PROXY_AUTH_ENABLED=0
API_AGENT_BOOTSTRAP_ENABLED=1
